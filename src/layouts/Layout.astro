---
import "@styles/print.css";
import "@styles/global.css";
import "@styles/background.css";
import "remixicon/fonts/remixicon.css";

import Footer from "@components/layout/Footer.astro";
import Header from "@components/layout/Header.astro";
import Hero from "@components/layout/Hero.astro";
import Sidebar from "@components/layout/Sidebar.astro";
import FloatingNav from "@components/layout/FloatingNav.astro";
import BackToTop from "@components/widgets/BackToTop.astro";
import type { MarkdownHeading } from "astro";

const SITE_TITLE = "HY博客";
const SITE_DESCRIPTION = "一个孤独的地方，散落着一个人的人生碎片";
const SITE_AUTHOR = "HY";
const OG_IMAGE_DEFAULT = "/default-social-image.png";
const TWITTER_HANDLE = "@h_myhy";
const GITHUB_URL = "https://github.com/himyhy";
const TELEGRAM_URL = "https://t.me/hy_post";

const navLinks = [
  { href: "/", label: "首页", icon: "ri-home-5-line" },
  { href: "/blog", label: "博客", icon: "ri-article-line" },
  { href: "/guestbook", label: "留言", icon: "ri-chat-smile-3-line" },
  { href: "/friends", label: "朋友", icon: "ri-group-line" },
];

interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props {
  title: string;
  description?: string;
  image?: string;
  keywords?: string[];
  headings?: MarkdownHeading[];
  showHero?: boolean;
  breadcrumbs?: BreadcrumbItem[] | null;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = SITE_DESCRIPTION,
  image = OG_IMAGE_DEFAULT,
  keywords = [],
  headings = [],
  showHero = title === "首页",
  breadcrumbs: providedBreadcrumbs,
  structuredData,
} = Astro.props;

const finalTitle = title === "首页" ? SITE_TITLE : `${title} | ${SITE_TITLE}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(image, Astro.site);
const currentPath = Astro.url.pathname;
const mobileDrawerId = "mobile-drawer";

const navLookup = new Map(navLinks.map((link) => [link.href, link.label]));

const buildDefaultBreadcrumbs = () => {
  if (title === "首页") return null;

  const segments = currentPath.split("/").filter(Boolean);
  const crumbs: BreadcrumbItem[] = [{ label: "首页", href: "/" }];

  if (segments.length === 0) {
    crumbs.push({ label: title });
    return crumbs;
  }

  segments.forEach((_, index) => {
    const path = `/${segments.slice(0, index + 1).join("/")}`;
    const isLast = index === segments.length - 1;

    if (!isLast) {
      const label = navLookup.get(path) ?? segments[index];
      crumbs.push({ label, href: path });
    }
  });

  crumbs.push({ label: title });
  return crumbs;
};

const breadcrumbs = providedBreadcrumbs ?? buildDefaultBreadcrumbs();

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE_TITLE,
  url: Astro.site,
  inLanguage: "zh-CN",
};

const breadcrumbSchema = breadcrumbs
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: breadcrumbs.map((item, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: item.label,
        ...(item.href
          ? { item: new URL(item.href, Astro.site).toString() }
          : { item: canonicalURL.toString() }),
      })),
    }
  : null;

const structuredDataList = [websiteSchema, breadcrumbSchema, structuredData]
  .flat()
  .filter(Boolean);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content={SITE_AUTHOR} />

    <title>{finalTitle}</title>
    <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(",")} />}
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" href="/favicon.ico" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/favicon.svg"
      media="(prefers-color-scheme: light)"
    />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/favicon-dark.svg"
      media="(prefers-color-scheme: dark)"
    />

    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:locale" content="zh_CN" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={TWITTER_HANDLE} />
    <meta name="twitter:title" content={finalTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />

    {
      structuredDataList.map((schema, index) => (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(schema)}
          data-schema-id={`seo-schema-${index}`}
        />
      ))
    }
  </head>
  <body class="bg-base-100 text-base-content min-h-screen topography">
    <Header
      siteTitle={SITE_TITLE}
      navLinks={navLinks}
      currentPath={currentPath}
      mobileDrawerId={mobileDrawerId}
    />

    <dialog id={mobileDrawerId} class="modal p-0 mobile-drawer" aria-label="移动端导航">
      <div class="flex w-screen h-[100dvh] justify-start">
        <div
          class="w-80 max-w-[80vw] sm:max-w-sm h-full bg-[linear-gradient(180deg,rgba(252,248,255,0.98)_0%,rgba(248,244,255,0.97)_100%)] shadow-2xl shadow-fuchsia-950/10 border-r border-fuchsia-100/80 flex flex-col drawer-panel overflow-hidden"
        >
          <div class="bg-white/50 backdrop-blur-md border-b border-fuchsia-100/70 px-4 py-3 flex items-center justify-between shrink-0">
            <div class="flex items-center gap-3 min-w-0">
              <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl ring-1 ring-fuchsia-400/20 shadow-sm bg-[linear-gradient(135deg,#7c3aed_0%,#a855f7_45%,#ec4899_100%)] text-white">
                <svg viewBox="0 0 24 24" class="h-5.5 w-5.5" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M4.7 6.2V17.8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                  <path d="M4.7 12.1C5.9 11.4 7.2 11.1 8.3 11.1C9.3 11.1 10 11.4 10.8 12.3" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M11.2 6.3C11.1 10.2 11.2 14.1 11.2 17.9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                  <path d="M12.7 8.2C14.1 6.9 15.5 6.2 16.8 6.2C18.2 6.2 19 7 19 8.1C19 9.6 17.4 10.6 15.8 11.7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M15.8 11.7C16.8 12.7 17.5 14.1 17.5 17.8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <div class="min-w-0 leading-tight">
                <p class="text-sm font-semibold tracking-tight">HY博客</p>
                <p class="text-[11px] text-base-content/50 truncate">所有的为时已晚都是恰逢其时</p>
              </div>
            </div>
            <button
              type="button"
              class="btn btn-sm btn-ghost btn-circle text-base-content/60 hover:bg-white/70 hover:text-base-content"
              aria-label="关闭导航"
              data-close-drawer="true"
            >
              ✕
            </button>
          </div>
          <div class="p-4 pt-3 space-y-5 overflow-y-auto flex-1 pb-16 custom-scrollbar">
            <nav class="flex flex-col gap-2" aria-label="主要导航">
              {navLinks.map((link) => {
                const isActive =
                  link.href === "/"
                    ? currentPath === "/"
                    : currentPath === link.href || currentPath.startsWith(`${link.href}/`);
                return (
                  <a
                    href={link.href}
                    class:list={{
                      "flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-medium transition-all duration-200": true,
                      "bg-[linear-gradient(135deg,#7c3aed_0%,#a855f7_45%,#ec4899_100%)] text-white shadow-lg shadow-fuchsia-300/30": isActive,
                      "text-base-content/75 hover:bg-white/75 hover:text-base-content": !isActive,
                    }}
                    aria-current={isActive ? "page" : undefined}
                  >
                    <i class={link.icon} aria-hidden="true" />
                    <span>{link.label}</span>
                  </a>
                );
              })}
            </nav>

            <div class="h-px bg-gradient-to-r from-transparent via-fuchsia-200/70 to-transparent my-2" />

            <div class="space-y-4 mobile-sidebar-shell">
              <Sidebar
                idPrefix="mobile-sidebar"
                headings={headings}
                author={SITE_AUTHOR}
                twitterHandle={TWITTER_HANDLE}
                githubUrl={GITHUB_URL}
                telegramUrl={TELEGRAM_URL}
              />
            </div>
          </div>
        </div>
        <button
          type="button"
          class="flex-1 h-full drawer-backdrop bg-black/10 hover:bg-black/20 transition-colors duration-300 ease-out"
          data-close-drawer="true"
          aria-label="点击关闭导航"
        >
          <span class="sr-only">关闭导航</span>
        </button>
      </div>
    </dialog>

    <style is:inline>
      .page-shell {
        transform-origin: top center;
        will-change: transform, filter, opacity;
        transition:
          transform 0.38s cubic-bezier(0.16, 1, 0.3, 1),
          filter 0.32s ease-out,
          opacity 0.32s ease-out;
      }

      .drawer-panel {
        transform: translate3d(-100%, 0, 0) scale(0.985);
        opacity: 0.94;
        will-change: transform, opacity;
        backface-visibility: hidden;
        transition:
          transform 0.38s cubic-bezier(0.16, 1, 0.3, 1),
          opacity 0.24s ease-out,
          box-shadow 0.38s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .mobile-sidebar-shell :global(aside) {
        display: block;
      }

      .mobile-sidebar-shell :global(aside > div) {
        position: static;
      }

      .mobile-sidebar-shell :global(.bg-base-200\/40) {
        background: rgba(255, 255, 255, 0.54) !important;
        border-color: rgba(244, 208, 255, 0.34) !important;
        border-radius: 1rem !important;
        box-shadow: 0 10px 28px rgba(168, 85, 247, 0.07);
        backdrop-filter: blur(12px);
      }

      .mobile-sidebar-shell :global(.bg-base-100) {
        background: rgba(255, 255, 255, 0.68) !important;
        border-color: rgba(244, 208, 255, 0.26) !important;
      }

      .mobile-sidebar-shell :global(.divider) {
        opacity: 0.35 !important;
      }

      .mobile-sidebar-shell :global(h3),
      .mobile-sidebar-shell :global(h4) {
        letter-spacing: -0.01em;
      }

      .mobile-sidebar-shell :global(.btn-ghost) {
        border-radius: 0.9rem;
      }

      .mobile-sidebar-shell :global(a.block.p-3.rounded-lg),
      .mobile-sidebar-shell :global(.flex.items-center.justify-between.bg-base-100.rounded-lg.p-3.border) {
        border-radius: 0.9rem !important;
        background: rgba(255, 255, 255, 0.7) !important;
        border-color: rgba(244, 208, 255, 0.22) !important;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.35);
      }

      .mobile-sidebar-shell :global(a.block.p-3.rounded-lg:hover),
      .mobile-sidebar-shell :global(.flex.items-center.justify-between.bg-base-100.rounded-lg.p-3.border:hover) {
        background: rgba(255, 255, 255, 0.82) !important;
        border-color: rgba(217, 70, 239, 0.28) !important;
      }

      .drawer-backdrop {
        opacity: 0;
        backdrop-filter: blur(0px);
        -webkit-backdrop-filter: blur(0px);
        will-change: opacity, backdrop-filter;
        transition:
          opacity 0.32s ease-out,
          background-color 0.32s ease-out,
          backdrop-filter 0.32s ease-out;
      }

      dialog[open].mobile-drawer ~ .page-shell {
        transform: scale(0.992);
        filter: blur(2px);
        opacity: 0.9;
      }

      dialog[open].mobile-drawer .drawer-panel {
        transform: translate3d(0, 0, 0) scale(1);
        opacity: 1;
      }

      dialog[open].mobile-drawer .drawer-backdrop {
        opacity: 1;
        background-color: rgb(0 0 0 / 0.18);
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
      }

      dialog.mobile-drawer.is-closing ~ .page-shell {
        transform: scale(1);
        filter: blur(0);
        opacity: 1;
      }

      dialog.mobile-drawer.is-closing .drawer-panel {
        transform: translate3d(-100%, 0, 0) scale(0.985);
        opacity: 0.98;
      }

      dialog.mobile-drawer.is-closing .drawer-backdrop {
        opacity: 0;
        backdrop-filter: blur(0);
        -webkit-backdrop-filter: blur(0);
      }

      @media (prefers-reduced-motion: reduce) {
        .drawer-panel,
        .drawer-backdrop {
          transition: none;
        }
      }
    </style>

    <div class="page-shell">
      {showHero && <Hero siteDescription={SITE_DESCRIPTION} />}

      <div
        id="main-content-grid"
        class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8"
      >
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-4">
          <main class="lg:col-span-3 min-h-[60vh]">
          {breadcrumbs && (
            <nav
              class="flex items-center gap-2 text-sm text-base-content/60 mb-8 no-print"
              aria-label="面包屑导航"
            >
              <ol class="flex items-center gap-2">
                {breadcrumbs.map((item, index) => {
                  const isLast = index === breadcrumbs.length - 1;
                  return (
                    <li class="flex items-center gap-2">
                      {index > 0 && (
                        <i class="ri-arrow-right-s-line text-base-content/40" aria-hidden="true"></i>
                      )}
                      {item.href && !isLast ? (
                        <a
                          href={item.href}
                          class="hover:text-primary transition-colors duration-200"
                        >
                          {item.label}
                        </a>
                      ) : (
                        <span
                          class:list={{
                            "text-base-content/80 font-medium": isLast,
                          }}
                        >
                          {item.label}
                        </span>
                      )}
                    </li>
                  );
                })}
              </ol>
            </nav>
          )}

          <slot />
        </main>

        <div class="hidden lg:block lg:col-span-1">
          <Sidebar
            idPrefix="desktop-sidebar"
            headings={headings}
            author={SITE_AUTHOR}
            twitterHandle={TWITTER_HANDLE}
            githubUrl={GITHUB_URL}
            telegramUrl={TELEGRAM_URL}
          />
        </div>
      </div>
    </div>

      <Footer
        author={SITE_AUTHOR}
        twitterHandle={TWITTER_HANDLE}
        githubUrl={GITHUB_URL}
        telegramUrl={TELEGRAM_URL}
      />

      <BackToTop />
      <FloatingNav />
    </div>
    <script is:inline>
      // 核心 UI 初始化：即使其他资源加载失败，也要保证侧边栏可用
      (function() {
        const initDrawer = () => {
          const mobileDrawerId = "mobile-drawer";
          const mobileDrawer = document.getElementById(mobileDrawerId);
          if (mobileDrawer instanceof HTMLDialogElement) {
            const panel = mobileDrawer.querySelector(".drawer-panel");
            const backdrop = mobileDrawer.querySelector(".drawer-backdrop");
            const closeDrawer = () => {
              if (!mobileDrawer.open) return;
              if (!panel) { mobileDrawer.close(); return; }

              mobileDrawer.classList.add("is-closing");

              let finished = false;
              const cleanup = () => {
                if (finished) return;
                finished = true;
                mobileDrawer.classList.remove("is-closing");
                panel.removeEventListener("transitionend", onEnd);
                backdrop?.removeEventListener("transitionend", onEnd);
                if (mobileDrawer.open) mobileDrawer.close();
              };

              const onEnd = (event) => {
                if (event.target !== panel || event.propertyName !== "transform") return;
                cleanup();
              };

              panel.addEventListener("transitionend", onEnd);
              backdrop?.addEventListener("transitionend", onEnd);
              window.setTimeout(cleanup, 400);
            };

            mobileDrawer.querySelectorAll("[data-close-drawer]").forEach(el => {
              el.onclick = (e) => { e.preventDefault(); closeDrawer(); };
            });
            mobileDrawer.addEventListener("cancel", (e) => { e.preventDefault(); closeDrawer(); });
          }
        };
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initDrawer);
        } else {
          initDrawer();
        }
      })();
    </script>
    <style is:inline>
      /* 强制侧边栏即便在字体加载失败时也有基础显示 */
      .drawer-panel { font-family: sans-serif; }
      /* 优化滚动条在国内旧版浏览器的表现 */
      .custom-scrollbar::-webkit-scrollbar { width: 4px; }
      .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.1); border-radius: 10px; }
    </style>
  </body>
</html>
