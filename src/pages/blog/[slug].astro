---
import "/node_modules/katex/dist/katex.min.css";
import type { CollectionEntry } from "astro:content";
import PostFooter from "@components/blog/PostFooter.astro";
import ShareButtons from "@components/blog/ShareButtons.astro";
import Comments from "@components/comments/Comments.astro";
import Figure from "@components/markdown/Figure.astro";
import Layout from "@layouts/Layout.astro";
import BlogLikeButton from "@/components/blog/LikeButton";
import ViewTracker from "@/components/blog/ViewTracker";
import { getAllPostsWithShortLinks } from "@/lib/blog";
import dayjs from "@/lib/telegram/dayjs-setup";

export const prerender = true;

export async function getStaticPaths() {
  const allPosts = await getAllPostsWithShortLinks(Astro.site!);
  return allPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog"> & { shortLink: string | null; longUrl: string };
}
const { post } = Astro.props;
const { Content, headings } = await post.render();
const {
  title,
  description,
  pubDate,
  updated,
  image,
  tags = [],
  categories = [],
} = post.data;

const author = "HY";
// --- 预计阅读时间计算 ---
// 中文阅读速度（字/分钟）
const chineseWPM = 300;
// 英文阅读速度（单词/分钟）
const englishWPM = 200;

// 移除 Markdown 格式，获得更纯净的文本内容
const plainText = post.body.replace(/---[\s\S]*?---/, ""); // 移除 frontmatter

// 匹配中文字符
const chineseChars = (plainText.match(/[\u4e00-\u9fa5]/g) || []).length;
// 匹配英文单词（包括带连字符的单词）
const englishWords = (plainText.match(/[a-zA-Z0-9'-]+/g) || []).length;

// 分别计算阅读时间，然后相加
const chineseMinutes = chineseChars / chineseWPM;
const englishMinutes = englishWords / englishWPM;
const totalMinutes = Math.ceil(chineseMinutes + englishMinutes);

// 最终显示的字数和阅读时间
const words = chineseChars + englishWords;
const readTime = `预计阅读 ${totalMinutes} 分钟`;

const shareUrl = post.shortLink || post.longUrl;

const ogImageUrl = `/og/${post.slug}.png`;
const seoKeywords = [
  ...new Set(["HY博客", "技术博客", ...categories, ...tags]),
];
const canonicalUrl = new URL(`/blog/${post.slug}/`, Astro.site).toString();

const articleStructuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  image: [new URL(ogImageUrl, Astro.site).toString()],
  datePublished: new Date(pubDate).toISOString(),
  dateModified: new Date(updated ?? pubDate).toISOString(),
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalUrl,
  },
  url: canonicalUrl,
  author: {
    "@type": "Person",
    name: author,
  },
  publisher: {
    "@type": "Organization",
    name: "HY博客",
    logo: {
      "@type": "ImageObject",
      url: new URL("/avatar.webp", Astro.site).toString(),
    },
  },
  inLanguage: "zh-CN",
  keywords: seoKeywords,
  articleSection: categories,
  wordCount: words,
  isAccessibleForFree: true,
};

const customComponents = {
  img: Figure,
};

const allPosts = await getAllPostsWithShortLinks(Astro.site!);
const currentTags = new Set(tags);
const currentCategories = new Set(categories);

const relatedPosts = allPosts
  .filter((p) => p.slug !== post.slug)
  .map((p) => {
    const pTags = p.data.tags || [];
    const pCategories = p.data.categories || [];

    const sharedTags = pTags.filter((t) => currentTags.has(t)).length;
    const sharedCategories = pCategories.filter((c) =>
      currentCategories.has(c),
    ).length;

    const score = sharedCategories * 3 + sharedTags * 2;

    return { post: p, score };
  })
  .filter((item) => item.score > 0)
  .sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score;
    return b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf();
  })
  .slice(0, 5)
  .map((item) => item.post);
---

<Layout
  title={title}
  description={description}
  image={ogImageUrl}
  keywords={seoKeywords}
  structuredData={articleStructuredData}
  headings={headings}
>
  <article class="max-w-4xl mx-auto">
    <ViewTracker client:only="react" slug={post.slug} />
    <header class="mb-12 animate-fade-in">
      {
        image && (
          <div class="relative aspect-[21/9] overflow-hidden rounded-3xl mb-8 shadow-2xl">
            <img
              src={image}
              alt={title}
              class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
              loading="eager"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent" />
          </div>
        )
      }

      <div class="space-y-6 no-print">
        <h1
          class="text-3xl md:text-4xl lg:text-5xl font-bold text-base-content leading-tight"
        >
          {title}
        </h1>
        <p class="text-sm md:text-mx text-base-content/70 leading-relaxed">
          {description}
        </p>

        <div
          class="flex flex-col sm:flex-row sm:items-center gap-6 p-6 bg-base-200/50 rounded-2xl border border-base-content/5"
        >
          <div class="flex items-center gap-4">
            <div
              class="w-12 h-12 rounded-full ring-2 ring-primary/20 ring-offset-2 ring-offset-base-100"
            >
              <img
                src="/avatar.webp"
                class="w-full h-full rounded-full object-cover"
                alt={author}
              />
            </div>
            <div class="flex flex-col">
              <span class="font-semibold text-base-content">{author}</span>
              <span class="text-sm text-base-content/60">Developer</span>
            </div>
          </div>

          <div class="hidden sm:block w-px h-8 bg-base-content/20"></div>

          <div class="flex flex-wrap gap-4 text-sm text-base-content/60">
            <div class="flex items-center gap-2">
              <i class="ri-calendar-line"></i>
              <span>{dayjs(pubDate).format("YYYY年MM月DD日")}</span>
            </div>
            {
              updated && (
                <div class="flex items-center gap-2">
                  <i class="ri-refresh-line" />
                  <span>更新于 {dayjs(updated).format("MM月DD日")}</span>
                </div>
              )
            }
            <div class="flex items-center gap-2">
              <i class="ri-time-line"></i>
              <span>{readTime}</span>
            </div>
            <div class="flex items-center gap-2">
              <i class="ri-book-open-line"></i>
              <span>{words} 字</span>
            </div>
          </div>
        </div>
      </div>
    </header>

    <main class="mb-12 animate-fade-in" style="animation-delay: 0.2s;">
      <div
        class="bg-base-200/40 backdrop-blur-sm rounded-2xl p-6 md:p-8 lg:p-12 shadow-sm border border-base-content/5"
      >
        <div class="prose max-w-none">
          <Content components={customComponents} />
        </div>
      </div>
    </main>

    <section
      class="my-16 flex flex-col items-center justify-center gap-4 animate-fade-in no-print"
      style="animation-delay: 0.4s;"
    >
      <h3 class="text-xl font-bold text-base-content">觉得这篇文章怎么样？</h3>
      <p class="text-base-content/70 -mt-2">点个赞，让更多人看到！</p>
      <div class="mt-4">
        <BlogLikeButton client:load postId={post.slug} />
      </div>
    </section>

    <section
      class="mb-12 animate-fade-in no-print"
      style="animation-delay: 0.4s;"
    >
      <ShareButtons title={title} url={shareUrl} description={description} />
    </section>

    <footer
      class="mb-12 animate-fade-in no-print"
      style="animation-delay: 0.6s;"
    >
      <PostFooter post={post} author={author} />
    </footer>

    {
      relatedPosts.length > 0 && (
        <section class="mb-14 animate-fade-in no-print" style="animation-delay: 0.8s;">
          <div class="rounded-2xl border border-base-content/8 bg-base-200/35 backdrop-blur-sm p-6 md:p-7">
            <div class="mb-5 flex items-center justify-between gap-3">
              <div class="flex items-center gap-2 text-base-content/85">
                <i class="ri-links-line text-lg" />
                <h3 class="text-lg font-bold">相关文章</h3>
              </div>
              <a href="/blog" class="text-sm text-primary hover:underline">查看更多</a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {relatedPosts.map((item) => (
                <a
                  href={`/blog/${item.slug}/`}
                  class="group rounded-xl border border-base-content/8 bg-base-100/70 p-4 transition-all duration-200 hover:border-primary/30 hover:bg-base-100 hover:shadow-md"
                >
                  <p class="line-clamp-2 font-semibold text-base-content group-hover:text-primary transition-colors">
                    {item.data.title}
                  </p>
                  <p class="mt-2 line-clamp-2 text-sm text-base-content/65">
                    {item.data.description}
                  </p>
                  <div class="mt-3 flex items-center justify-between text-xs text-base-content/55">
                    <span>{dayjs(item.data.pubDate).format("YYYY-MM-DD")}</span>
                    <span class="inline-flex items-center gap-1 group-hover:text-primary/80">
                      阅读
                      <i class="ri-arrow-right-line" />
                    </span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <section
      class="mb-16 animate-fade-in no-print"
      style="animation-delay: 1s;"
    >
      <Comments identifier={post.slug} commentType="blog" />
    </section>
  </article>
</Layout>
