---
import SearchBar from "@components/widgets/SearchBar";

export interface Props {
  siteTitle: string;
  navLinks: { href: string; label: string; icon?: string }[];
  currentPath: string;
  mobileDrawerId: string;
}
const { siteTitle, navLinks = [], currentPath, mobileDrawerId } = Astro.props;
---

<header
  class="glass-header sticky top-0 z-50 backdrop-blur-lg no-print"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-14">
      <div class="flex items-center space-x-3">
        <a
          href="/"
          class="flex items-center space-x-2 group"
          aria-controls={mobileDrawerId}
          aria-haspopup="dialog"
          onclick={`event.preventDefault(); document.getElementById('${mobileDrawerId}')?.showModal?.();`}
        >
          <div
            class="w-10 h-10 rounded-2xl ring-1 ring-fuchsia-400/20 shadow-sm group-hover:scale-110 transition-transform duration-300 bg-[linear-gradient(135deg,#7c3aed_0%,#a855f7_45%,#ec4899_100%)] text-white flex items-center justify-center"
            aria-hidden="true"
          >
            <svg viewBox="0 0 24 24" class="w-[1.45rem] h-[1.45rem]" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M4.7 6.2V17.8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
              <path d="M4.7 12.1C5.9 11.4 7.2 11.1 8.3 11.1C9.3 11.1 10 11.4 10.8 12.3" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M11.2 6.3C11.1 10.2 11.2 14.1 11.2 17.9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
              <path d="M12.7 8.2C14.1 6.9 15.5 6.2 16.8 6.2C18.2 6.2 19 7 19 8.1C19 9.6 17.4 10.6 15.8 11.7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M15.8 11.7C16.8 12.7 17.5 14.1 17.5 17.8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span
            class="text-lg font-bold bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent hidden md:block"
          >
            {siteTitle}
          </span>
        </a>
      </div>

      <div class="flex items-center gap-3 lg:gap-6">
        <nav
          class="hidden md:flex items-center gap-4 text-sm font-medium"
          aria-label="主导航"
        >
          {navLinks.map((link) => {
            const isActive =
              link.href === "/"
                ? currentPath === "/"
                : currentPath === link.href || currentPath.startsWith(`${link.href}/`);
            return (
              <a
                href={link.href}
                class:list={{
                  "relative inline-flex items-center gap-1 transition-colors": true,
                  "text-primary font-semibold": isActive,
                  "text-base-content/70 hover:text-primary": !isActive,
                }}
                aria-current={isActive ? "page" : undefined}
              >
                {link.icon && <i class={link.icon} aria-hidden="true"></i>}
                <span>{link.label}</span>
                {isActive && (
                  <span class="absolute -bottom-1 left-0 w-full h-0.5 bg-gradient-to-r from-primary to-secondary rounded-full"></span>
                )}
              </a>
            );
          })}
        </nav>

        <SearchBar client:idle />
      </div>
    </div>
  </div>
</header>

<style>
  .glass-header {
    background: linear-gradient(
      135deg,
      rgba(250, 245, 255, 0.72) 0%,
      rgba(245, 240, 255, 0.68) 45%,
      rgba(240, 244, 255, 0.66) 100%
    );
    border-bottom: 1px solid rgba(244, 208, 255, 0.3);
    box-shadow: 0 1px 10px rgba(217, 70, 239, 0.08);
  }

  @media (prefers-color-scheme: dark) {
    .glass-header {
      background: linear-gradient(
        135deg,
        rgba(28, 16, 45, 0.72) 0%,
        rgba(33, 24, 56, 0.68) 45%,
        rgba(24, 30, 58, 0.66) 100%
      );
      border-bottom-color: rgba(168, 85, 247, 0.22);
      box-shadow: 0 1px 12px rgba(76, 29, 149, 0.22);
    }
  }
</style>
