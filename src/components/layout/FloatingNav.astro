<div class="fixed bottom-24 right-6 md:bottom-28 md:right-8 flex flex-col gap-3 z-40 no-print opacity-0 invisible" id="floating-nav">
  <!-- 首页按钮 -->
  <a
    href="/"
    class="w-12 h-12 rounded-full bg-primary text-primary-content shadow-lg hover:shadow-xl hover:scale-110 transition-all flex items-center justify-center group"
    title="首页"
  >
    <i class="ri-home-line text-xl"></i>
  </a>

  <!-- 博客按钮 -->
  <a
    href="/blog"
    class="w-12 h-12 rounded-full bg-primary text-primary-content shadow-lg hover:shadow-xl hover:scale-110 transition-all flex items-center justify-center group"
    title="博客"
  >
    <i class="ri-article-line text-xl"></i>
  </a>
</div>

<script>
  const floatingNav = document.getElementById("floating-nav");

  const updateFloatingNavVisibility = () => {
    if (!floatingNav) return;
    const threshold = Math.max(160, window.innerHeight * 0.35);
    if (window.scrollY > threshold) {
      floatingNav.classList.remove("opacity-0", "invisible");
      floatingNav.classList.add("opacity-100", "visible");
    } else {
      floatingNav.classList.add("opacity-0", "invisible");
      floatingNav.classList.remove("opacity-100", "visible");
    }
  };

  window.addEventListener("scroll", updateFloatingNavVisibility);
  window.addEventListener("resize", updateFloatingNavVisibility);
  updateFloatingNavVisibility();
</script>

<style>
  #floating-nav {
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
</style>
