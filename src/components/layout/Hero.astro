---
// src/components/layout/Hero.astro
import { Icon } from "astro-icon/components";

export interface Props {
  siteDescription: string;
}

const { siteDescription } = Astro.props;

// 显示层支持两行简介：
// 1) 若包含“。”：按第一句句号分行
// 2) 否则若包含“这里”：在“这里”前分行
// （不影响 <meta name="description">）
const splitDescription = () => {
  const idx = siteDescription.indexOf("。");
  if (idx !== -1) {
    const line1 = siteDescription.slice(0, idx + 1);
    const line2 = siteDescription.slice(idx + 1).trim();
    return { line1, line2 };
  }

  const marker = "这里";
  const markerIdx = siteDescription.indexOf(marker);
  if (markerIdx !== -1) {
    const line1 = siteDescription.slice(0, markerIdx).trim();
    const line2 = siteDescription.slice(markerIdx).trim();
    return { line1, line2 };
  }

  return { line1: siteDescription, line2: "" };
};

const { line1, line2 } = splitDescription();
---

<section class="relative overflow-hidden">
  <div
    class="absolute top-0 left-1/4 w-96 h-96 bg-primary/20 rounded-full filter blur-3xl opacity-50 animate-blob"
  >
  </div>
  <div
    class="absolute bottom-0 right-1/4 w-96 h-96 bg-secondary/20 rounded-full filter blur-3xl opacity-50 animate-blob animation-delay-4000"
  >
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-24 md:py-32">
    <div class="text-center max-w-3xl mx-auto">
      <h1
        class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 bg-gradient-to-r from-primary via-secondary to-accent bg-clip-text text-transparent leading-tight tracking-tight"
        transition:animate="fade"
      >
        时光碎片
      </h1>
      <p
        class="text-lg text-base-content/80 mb-10 leading-relaxed"
        transition:animate="slide"
      >
        {line1}
        {line2 && (
          <>
            <br />
            {line2}
          </>
        )}
      </p>

      <div class="flex justify-center gap-4" transition:animate="fade">
        <a
          href="/blog"
          class="btn btn-primary btn-soft flex items-center gap-2 rounded-xl"
        >
          <Icon name="ri:article-line" class="w-5 h-5" />
          博客文章
        </a>
        <a
          href="/guestbook"
          class="btn btn-secondary btn-soft flex items-center gap-2 rounded-xl"
        >
          <Icon name="ri:message-3-line" class="w-5 h-5" />
          留言记录
        </a>
      </div>

      <div
        class="mt-12 flex flex-wrap items-center justify-center gap-3 text-sm text-base-content/70"
        transition:animate="fade"
      >
        <span class="rounded-full border border-primary/12 bg-base-100/45 px-4 py-2 backdrop-blur-sm">前端开发</span>
        <span class="rounded-full border border-secondary/12 bg-base-100/45 px-4 py-2 backdrop-blur-sm">AI / 自动化</span>
        <span class="rounded-full border border-accent/12 bg-base-100/45 px-4 py-2 backdrop-blur-sm">数字花园</span>
      </div>
    </div>
  </div>

  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-32 md:h-40 bg-gradient-to-b from-transparent via-base-100/45 to-base-100"></div>
  <div class="pointer-events-none absolute left-1/2 bottom-0 h-24 w-[34rem] -translate-x-1/2 rounded-full bg-primary/10 blur-3xl"></div>
</section>

<style>
  .animate-blob {
    animation: blob 7s infinite;
  }

  .animation-delay-4000 {
    animation-delay: -4s;
  }

  @keyframes blob {
    0% {
      transform: translate(0px, 0px) scale(1);
    }
    33% {
      transform: translate(30px, -50px) scale(1.1);
    }
    66% {
      transform: translate(-20px, 20px) scale(0.9);
    }
    100% {
      transform: translate(0px, 0px) scale(1);
    }
  }
</style>
