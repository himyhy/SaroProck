---
// src/components/layout/Hero.astro
import { Icon } from "astro-icon/components";

export interface Props {
  siteDescription: string;
}

const { siteDescription } = Astro.props;

// 显示层支持两行简介：
// 1) 若包含“。”：按第一句句号分行
// 2) 否则若包含“这里”：在“这里”前分行
// （不影响 <meta name="description">）
const splitDescription = () => {
  const idx = siteDescription.indexOf("。");
  if (idx !== -1) {
    const line1 = siteDescription.slice(0, idx + 1);
    const line2 = siteDescription.slice(idx + 1).trim();
    return { line1, line2 };
  }

  const marker = "这里";
  const markerIdx = siteDescription.indexOf(marker);
  if (markerIdx !== -1) {
    const line1 = siteDescription.slice(0, markerIdx).trim();
    const line2 = siteDescription.slice(markerIdx).trim();
    return { line1, line2 };
  }

  return { line1: siteDescription, line2: "" };
};

const { line1, line2 } = splitDescription();
---

<section class="relative overflow-hidden">
  <div
    class="absolute top-0 left-1/4 w-96 h-96 bg-primary/20 rounded-full filter blur-3xl opacity-50 animate-blob"
  >
  </div>
  <div
    class="absolute bottom-0 right-1/4 w-96 h-96 bg-secondary/20 rounded-full filter blur-3xl opacity-50 animate-blob animation-delay-4000"
  >
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 pt-24 pb-40 md:pt-32 md:pb-52">
    <div class="relative text-center max-w-3xl mx-auto isolate">
      <div class="pointer-events-none absolute inset-x-6 top-8 -z-10 h-56 rounded-full bg-[radial-gradient(circle,rgba(168,85,247,0.18)_0%,rgba(59,130,246,0.10)_35%,transparent_72%)] blur-2xl"></div>
      <div class="inline-flex items-center gap-2 rounded-full border border-primary/12 bg-base-100/20 px-4 py-1.5 text-xs tracking-[0.22em] uppercase text-primary/80 backdrop-blur-sm mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
        HY BLOG
      </div>
      <h1
        class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 bg-gradient-to-r from-primary via-secondary to-accent bg-clip-text text-transparent leading-tight tracking-tight drop-shadow-[0_8px_30px_rgba(168,85,247,0.18)]"
        transition:animate="fade"
      >
        时光碎片
      </h1>
      <p
        class="text-lg text-base-content/80 mb-10 leading-relaxed"
        transition:animate="slide"
      >
        {line1}
        {line2 && (
          <>
            <br />
            {line2}
          </>
        )}
      </p>

      <div class="flex justify-center gap-4" transition:animate="fade">
        <a
          href="/blog"
          class="btn btn-primary btn-soft flex items-center gap-2 rounded-xl"
        >
          <Icon name="ri:article-line" class="w-5 h-5" />
          博客文章
        </a>
        <a
          href="/guestbook"
          class="btn btn-secondary btn-soft flex items-center gap-2 rounded-xl"
        >
          <Icon name="ri:message-3-line" class="w-5 h-5" />
          留言记录
        </a>
      </div>

      <div
        class="mt-12 flex items-center justify-center space-x-6 text-sm text-base-content/60"
        transition:animate="fade"
      >
        <div class="flex items-center space-x-2">
          <Icon name="ri:map-pin-line" class="w-4 h-4 text-primary" />
          <span>数字世界</span>
        </div>
        <div class="flex items-center space-x-2">
          <Icon name="ri:time-line" class="w-4 h-4 text-primary" />
          <span>持续更新</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .animate-blob {
    animation: blob 7s infinite;
  }

  .animation-delay-4000 {
    animation-delay: -4s;
  }

  @keyframes blob {
    0% {
      transform: translate(0px, 0px) scale(1);
    }
    33% {
      transform: translate(30px, -50px) scale(1.1);
    }
    66% {
      transform: translate(-20px, 20px) scale(0.9);
    }
    100% {
      transform: translate(0px, 0px) scale(1);
    }
  }
</style>
